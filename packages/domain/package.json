{
  "name": "@ContribLens/domain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Versioned analytics contracts and definitions for the GitHub Contribution Analytics Engine.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "typecheck": "tsc --noEmit"
  }
}
