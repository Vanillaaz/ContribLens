{
  "name": "@ContribLens/observability",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Structured logging and observability utilities.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pino-pretty": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}