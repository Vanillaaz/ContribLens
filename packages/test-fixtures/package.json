{
  "name": "@ContribLens/test-fixtures",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Recorded and synthetic GitHub API responses for tests.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
